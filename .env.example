# Splunk Enterprise connection settings. Copy to .env and fill in. Never commit .env.
# Management/REST API URL (port 8089). If you omit the port, :8089 is assumed.
SPLUNK_URL=https://192.0.2.50:8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=changeme
# HTTP Event Collector (HEC) endpoint (port 8088) + a token, for sending events.
# If SPLUNK_HEC_URL is unset it is derived from SPLUNK_URL's host with :8088.
# SPLUNK_HEC_URL=https://192.0.2.50:8088
# SPLUNK_HEC_TOKEN=00000000-0000-0000-0000-000000000000
# Verify the Splunk TLS certificate (labs usually use self-signed).
SPLUNK_VERIFY_SSL=false
# Per-request timeout in seconds (searches can be slow).
SPLUNK_TIMEOUT=60
# Retries on transient transport failures (connect/read timeouts, resets).
SPLUNK_RETRIES=2
